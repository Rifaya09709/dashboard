{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.ts",
    "controllers/**/*.ts",
    "routes/**/*.ts",
    "models/**/*.ts",
    "middleware/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}